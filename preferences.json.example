{
  "_doc": "会話で育てる設定ファイル。chat.py の preferences_update JSON フィールドで Claude が書き込む。このファイルはサンプル。実際の設定は preferences.json に保存される（.gitignore 済み）。",
  "character_name": "Claude",
  "wake_words": ["ねえクロード", "クロード"],

  "tts_entity": "tts.home_assistant_cloud",
  "_tts_options_doc": "VOICEVOX通常発話の個体別設定。tts_entityがtts.voicevox_ttsのときだけ使用する。空でなければspeaker（0以上の整数）が必須。volumeは0.5〜2.0、pitchは-0.15〜0.15、speedは0.5〜3.0。空ならHA統合の既定値を使う。",
  "tts_options": {},
  "sing_speaker": {"name": "春日部つむぎ", "style_id": 3008},
  "stt_provider": "stt.home_assistant_cloud",
  "stt_language": "ja-JP",

  "_cameras_doc": "entity: HAエンティティIDか独自の短いID（電脳体侵入時に使う）。HAエンティティなら entity = source = ha_entity でよい。go2rtcの場合は entity に独自IDを設定し ha_entity で画像取得先のHAカメラを指定する。",
  "cameras": [
    {
      "entity": "camera_tv",
      "source": "living_tv_stream",
      "room": "living",
      "label": "テレビ",
      "note": "HDDレコーダー出力。今何が放送されているか確認できる"
    },
    {
      "entity": "camera.living_room_entity_id",
      "source": "camera.living_room_entity_id",
      "ha_entity": "camera.living_room_entity_id",
      "room": "living",
      "label": "リビング",
      "note": "リビングの広角カメラ"
    }
  ],

  "_audio_sources_doc": "entity: HAエンティティIDか独自の短いID（電脳体侵入時に使う）。rtsp/alsa/tcp など非HAのものは独自IDを設定する。",
  "audio_sources": [
    {
      "entity": "mic_tv",
      "source": "rtsp://localhost:8554/living_tv_stream",
      "label": "TV・レコーダー",
      "room": "living",
      "note": "go2rtc経由のTV/レコーダー音声",
      "stt_enabled": false,
      "stt_retention_hours": 0,
      "wake_word_enabled": false,
      "background_hearing_enabled": false
    },
    {
      "entity": "mic_alsa",
      "source": "alsa://default",
      "label": "スタディマイク",
      "room": "study",
      "note": "USBマイク直接録音（/dev/snd 必要）",
      "stt_enabled": true,
      "stt_retention_hours": 24,
      "wake_word_enabled": true,
      "background_hearing_enabled": true
    },
    {
      "entity": "mic_node_kitchen",
      "source": "tcp://192.168.1.xxx:3333",
      "label": "廊下 VoiceS3R",
      "room": "hallway",
      "note": "常時計測用の固定IPノード",
      "stt_enabled": true,
      "stt_retention_hours": 24,
      "wake_word_enabled": true,
      "background_hearing_enabled": true
    }
  ],

  "_speakers_doc": "entity: HAエンティティIDか独自の短いID（電脳体侵入時に使う）。ttsタイプは entity = media_player entity_id。TTSエンティティはグローバルの tts_entity を参照する。",
  "speakers": [
    {
      "entity": "media_player.your_tts_media_player",
      "room": "study",
      "label": "書斎（Nest Mini）",
      "type": "tts",
      "note": ""
    },
    {
      "entity": "notify.living_alexa_speak",
      "room": "living",
      "label": "リビング（Alexa）",
      "type": "notify",
      "note": ""
    },
    {
      "entity": "notify.bedroom_alexa_speak",
      "room": "bedroom",
      "label": "寝室（Alexa）",
      "type": "notify",
      "note": ""
    },
    {
      "entity": "notify.mobile_app_your_phone",
      "room": "away",
      "label": "外出先（スマホ）",
      "type": "notify",
      "title": "Embodied HA",
      "note": ""
    },
    {
      "entity": "mic_node_kitchen",
      "room": "hallway",
      "label": "廊下（VoiceS3R）",
      "type": "tcp",
      "host": "192.168.1.xxx",
      "port": 3334,
      "note": ""
    }
  ],

  "_entities_doc": "操作できる家電の対応表（口語の呼び方 → entity_id）。チャットで家電操作を頼まれたとき entity_id を引くのに使う。Web UIで編集・discover.pyで下書き生成・チャットの entities_add でも追記可。name は HA の friendly_name そのままでよい。",
  "entities": [
    {
      "name": "リビングのライト",
      "entity_id": "light.living_room",
      "note": ""
    }
  ],
  "presence": {
    "entity": "input_boolean.resident_home"
  },
  "policies": [
    "深夜1〜6時は発話しない（loop/explore に組み込み済み）"
  ],
  "_loop_schedule_doc": "自律ループ(loop.py)の定期実行間隔と、時間帯ごとの発火確率。loop_interval は秒。0-7時=night、22-24時=late、それ以外=day。Web UIの「高度な設定」タブから編集可能。",
  "loop_schedule": {
    "loop_interval": 1800,
    "day_probability": 100,
    "late_probability": 30,
    "night_probability": 10
  },

  "_sensors_doc": "自律ループ(loop)/会話(chat)で毎回コンテキストに渡す『おもなデバイス』センサーの定義。render-sensors.py が HA Template API で描画する。全エンティティは ha_get ツールで常時 pull 可能なので、ここに無い＝見えないではなく『自分から取りに行く対象』になるだけ。discover.py で下書きを自動生成できる。",
  "sensors": {
    "groups": [
      {
        "title": "人感センサー",
        "contexts": [
          "loop"
        ],
        "items": [
          {
            "label": "リビング",
            "entity": "binary_sensor.living_motion"
          },
          {
            "label": "廊下1",
            "entity": "binary_sensor.hall_motion_1",
            "note": "リビング誤反応あり"
          }
        ]
      },
      {
        "title": "温湿度",
        "contexts": [
          "loop"
        ],
        "items": [
          {
            "label": "リビング",
            "template": "{{ states('sensor.living_temp') }}℃ / {{ states('sensor.living_humidity') }}%"
          }
        ]
      },
      {
        "title": "テレビ",
        "contexts": [
          "loop"
        ],
        "items": [
          {
            "label": "最前面アプリ",
            "template": "{{ state_attr('media_player.android_tv_xxx','app_name') or state_attr('media_player.android_tv_xxx','source') or 'オフ' }}",
            "note": "HAのAndroid TV(ADB)統合のmedia_player。今見ているアプリ。要統合導入"
          }
        ]
      },
      {
        "contexts": [
          "chat"
        ],
        "items": [
          {
            "label": "在宅",
            "entity": "input_boolean.resident_home"
          },
          {
            "template": "人感→ リビング:{{ states('binary_sensor.living_motion') }}"
          }
        ]
      }
    ]
  },
  "ai_lounge": {
    "app_id": "",
    "installation_id": "",
    "auto_approve": false
  }
}
