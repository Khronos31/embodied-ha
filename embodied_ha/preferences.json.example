{
  "_doc": "会話で育てる設定ファイル。chat.py の preferences_update JSON フィールドで Claude が書き込む。このファイルはサンプル。実際の設定は preferences.json に保存される（.gitignore 済み）。",
  "character_name": "Claude",
  "wake_words": [
    "ねえクロード",
    "クロード"
  ],
  "tts_entity": "tts.home_assistant_cloud",
  "sing_speaker": {"name": "春日部つむぎ", "style_id": 3008},
  "stt_provider": "stt.home_assistant_cloud",
  "stt_language": "ja-JP",
  "_cameras_doc": "カメラ（目）: 侵入して見る実デバイス。entity は侵入時の ID、source は HA エンティティ ID か go2rtc / 直接 URL。ptz は必要なカメラだけ設定する。",
  "cameras": [
    {
      "entity": "camera.living_room_live_view",
      "source": "camera.living_room_live_view",
      "room": "living",
      "label": "リビングの見守りカメラ",
      "ptz": {
        "up": "up",
        "down": "down",
        "left": "left",
        "right": "right"
      },
      "note": "部屋を見るための実カメラ"
    },
    {
      "entity": "camera.study_webcam",
      "source": "camera.study_webcam",
      "room": "study",
      "label": "書斎Webカメラ",
      "note": "作業中の様子を見る"
    }
  ],
  "_speakers_doc": "スピーカーデバイス一覧。entity: HAエンティティIDか独自の短いID（電脳体侵入時に使う）。tts タイプは entity = media_player entity_id。TTSエンティティはグローバルの tts_entity を参照する。tcp タイプは raw PCM を TCP ソケットに送信する（VoiceS3R 等）。",
  "speakers": [
    {
      "entity": "media_player.your_tts_media_player",
      "room": "study",
      "label": "書斎（Nest Mini）",
      "type": "tts",
      "note": "tts_entity はグローバル設定を使用"
    },
    {
      "entity": "mic_node_kitchen",
      "room": "hallway",
      "label": "廊下（VoiceS3R）",
      "type": "tcp",
      "host": "192.168.1.xxx",
      "port": 3334,
      "note": "VoiceS3R スピーカー。tts_provider はグローバルの tts_entity から自動取得"
    }
  ],
  "_entities_doc": "操作できる家電の対応表（口語の呼び方 → entity_id）。チャットで家電操作を頼まれたとき entity_id を引くのに使う。Web UIで編集・discover.pyで下書き生成・チャットの entities_add でも追記可。name は HA の friendly_name そのままでよい。",
  "entities": [
    {
      "name": "リビングのライト",
      "entity_id": "light.living_room",
      "note": ""
    }
  ],
  "presence": {
    "entity": "input_boolean.resident_home"
  },
  "policies": [
    "深夜1〜6時は発話しない（loop/explore に組み込み済み）"
  ],
  "_loop_schedule_doc": "自律ループ(loop.py)の定期実行間隔と、時間帯ごとの発火確率。loop_interval は秒。0-7時=night、22-24時=late、それ以外=day。Web UIの「高度な設定」タブから編集可能。",
  "loop_schedule": {
    "loop_interval": 1800,
    "day_probability": 100,
    "late_probability": 30,
    "night_probability": 10
  },
  "_sensors_doc": "自律ループ(loop)/会話(chat)で毎回コンテキストに渡す『おもなデバイス』センサーの定義。render-sensors.py が HA Template API で描画する。全エンティティは ha_get ツールで常時 pull 可能なので、ここに無い＝見えないではなく『自分から取りに行く対象』になるだけ。discover.py で下書きを自動生成できる。",
  "sensors": {
    "groups": [
      {
        "title": "人感センサー",
        "contexts": [
          "loop"
        ],
        "items": [
          {
            "label": "リビング",
            "entity": "binary_sensor.living_motion"
          },
          {
            "label": "廊下1",
            "entity": "binary_sensor.hall_motion_1",
            "note": "リビング誤反応あり"
          }
        ]
      },
      {
        "title": "温湿度",
        "contexts": [
          "loop"
        ],
        "items": [
          {
            "label": "リビング",
            "template": "{{ states('sensor.living_temp') }}℃ / {{ states('sensor.living_humidity') }}%"
          }
        ]
      },
      {
        "title": "テレビ",
        "contexts": [
          "loop"
        ],
        "items": [
          {
            "label": "最前面アプリ",
            "template": "{{ state_attr('media_player.android_tv_xxx','app_name') or state_attr('media_player.android_tv_xxx','source') or 'オフ' }}",
            "note": "HAのAndroid TV(ADB)統合のmedia_player。今見ているアプリ。要統合導入"
          }
        ]
      },
      {
        "contexts": [
          "chat"
        ],
        "items": [
          {
            "label": "在宅",
            "entity": "input_boolean.resident_home"
          },
          {
            "template": "人感→ リビング:{{ states('binary_sensor.living_motion') }}"
          }
        ]
      }
    ]
  },
  "_mics_doc": "マイク（耳）: 侵入して聴く実デバイス。entity は侵入時の ID、source は HA エンティティ ID か外部入力の識別子。stt_enabled で文字起こし対象を切り替える。",
  "_video_media_doc": "映像ソース（観る）: 侵入不要で届くフレーム。id はメディア用 ID、source は camera_proxy / go2rtc / 直接 URL など。room は文脈用。",
  "_audio_media_doc": "音声ソース（聴く）: 侵入不要で届く音。id はメディア用 ID、source は音声取得元。video_media で対応する映像ソースを参照できる。",
  "mics": [
    {
      "entity": "mic_alsa_default",
      "source": "alsa://default",
      "room": "study",
      "label": "書斎マイク",
      "stt_enabled": true
    },
    {
      "entity": "mic_node_hallway",
      "source": "tcp://192.168.1.xxx:3333",
      "room": "hallway",
      "label": "廊下 VoiceS3R",
      "stt_enabled": true
    }
  ],
  "video_media": [
    {
      "id": "capture_tv",
      "source": "camera.living_room_tv_proxy",
      "room": "living",
      "label": "テレビ映像",
      "note": "レコーダー/TVの画面"
    },
    {
      "id": "home_pc_screenshot",
      "source": "camera.study_pc_screenshot",
      "room": "study",
      "label": "書斎PC画面",
      "note": "スクリーンショットの取得元"
    }
  ],
  "audio_media": [
    {
      "id": "capture_tv_audio",
      "source": "capture_tv",
      "room": "living",
      "label": "テレビ音声",
      "note": "テレビ映像とペア",
      "video_media": "capture_tv"
    },
    {
      "id": "capture_pc_audio",
      "source": "capture_pc2",
      "room": "study",
      "label": "PC音声",
      "note": "PC画面の音",
      "video_media": "home_pc_screenshot"
    }
  ]
}
